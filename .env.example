# IPInfo API token — get yours at https://ipinfo.io/account/token
IPINFO_TOKEN=your_token_here

# How long (in seconds) to cache the upstream dnsmasq list before re-downloading
# 3600 = 1 hour, 86400 = 24 hours
UPSTREAM_CACHE_TTL=3600

# How long (in seconds) to cache IPInfo geolocation results per IP
# 604800 = 7 days
GEO_CACHE_TTL=604800
